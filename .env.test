PORT=5000
MONGO_URI="mongodb://localhost:27017/test"
CLIENT_URL="http://localhost:5173"
SERVER_URL="http://localhost:8000"

# Migration env
MIGRATE_MONGO_URI=""
MIGRATE_MIGRATIONS_PATH="./migrations"
MIGRATE_AUTOSYNC="true"

# JWT Tokens
REFRESH_TOKEN_SECRET=test-refresh-secret-key-for-testing-only-minimum-16-chars
REFRESH_TOKEN_EXPIRY=7d
ACCESS_TOKEN_SECRET=test-access-secret-key-for-testing-only-minimum-16-chars
ACCESS_TOKEN_EXPIRY=15m

# Email variables
EMAIL_HOST=smtp.test.com
EMAIL_PORT=587
EMAIL_USER=test@test.com
EMAIL_PASS=test-password

# Google variables
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Cloudinary variables
CLOUDINARY_CLOUD_NAME="test-cloud"
CLOUDINARY_API_KEY="test-api-key"
CLOUDINARY_API_SECRET="test-api-secret"


NODE_ENV=test